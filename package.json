{
  "name": "app-conveyor",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun --watch run index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "gen-crds": "bun scripts/gen-crds.ts",
    "test:crds": "bash scripts/test-crds.sh",
    "test:reconciler": "bash scripts/test-reconciler.sh",
    "check": "bunx biome check && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@happy-dom/global-registrator": "^20.8.9",
    "@types/bun": "latest",
    "@types/node": "^25.5.0"
  },
  "engines": {
    "bun": "1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "zod": "^4.3.6"
  }
}
